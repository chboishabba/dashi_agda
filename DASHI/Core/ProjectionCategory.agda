module DASHI.Core.ProjectionCategory where

open import Agda.Builtin.Equality using (_≡_; refl)
open import Agda.Builtin.List using (List; []; _∷_)
open import Agda.Builtin.String using (String)
open import Agda.Builtin.Sigma using (Σ; _,_)
open import Agda.Builtin.Unit using (⊤; tt)

----------------------------------------------------------------------
-- ProjectionCategory: the core category generated by a grammar.
--
-- Every DASHI grammar Γ yields a projection category 𝓟Γ with:
--   Objects  — the admissible carrier/observable types
--   Morphisms — the admissible projections, transports, refinements
--   Identity — the trivial (do-nothing) projection
--   Composition — sequential projection through intermediate surfaces
--
-- Laws (id-left, id-right, assoc) are stated as postulated fields
-- so that each concrete instance can decide how strictly it satisfies
-- them (propositional, judgmental, or conditional).
--
--   Γ ↦ 𝓟Γ
----------------------------------------------------------------------

record ProjectionCategory : Set₁ where
  field
    Obj : Set
    Hom : Obj → Obj → Set
    id  : ∀ {A} → Hom A A
    _∘_ : ∀ {A B C} → Hom B C → Hom A B → Hom A C

    -- Category laws (postulated; may be conditional or propositional)
    id-left  : ∀ {A B} (f : Hom A B) → id ∘ f ≡ f
    id-right : ∀ {A B} (f : Hom A B) → f ∘ id ≡ f
    assoc    : ∀ {A B C D} (f : Hom C D) (g : Hom B C) (h : Hom A B)
             → (f ∘ g) ∘ h ≡ f ∘ (g ∘ h)

  -- Hom-set recoverable as HomᵦΓ(A,B)
  HomSet : Obj → Obj → Set
  HomSet A B = Hom A B

  -- Guards
  field
    categoryReading : String

open ProjectionCategory public

----------------------------------------------------------------------
-- Canonical instance (all types ⊤, trivial composition)
----------------------------------------------------------------------

canonicalProjectionCategory : ProjectionCategory
canonicalProjectionCategory = record
  { Obj             = ⊤
  ; Hom             = λ _ _ → ⊤
  ; id              = tt
  ; _∘_             = λ _ _ → tt
  ; id-left         = λ _ → refl
  ; id-right        = λ _ → refl
  ; assoc           = λ _ _ _ → refl
  ; categoryReading = "Canonical ProjectionCategory: all types ⊤, trivial category."
  }
