module DASHI.Core.NSAIFormalism where

open import Agda.Builtin.Bool using (Bool; false; true)
open import Agda.Builtin.Equality using (_≡_; refl)
open import Agda.Builtin.List using (List; []; _∷_)
open import Agda.Builtin.Sigma using (Σ; _,_)
open import Agda.Builtin.String using (String)
open import Agda.Builtin.Unit using (⊤; tt)

import DASHI.Core.ProjectionGrammar as PG

----------------------------------------------------------------------
-- 1. Learner: neural/statistical selector inside a grammar-generated
--    Hom-space.
--
-- The "neural" part of NS-AI is not the whole system.  It is a
-- morphism selector inside a grammar-generated admissible space.
-- SGD does not discover truth; it selects an inhabitant of Hom_Γ.
----------------------------------------------------------------------

record Learner (G : PG.ProjectionGrammar) : Set₁ where
  open PG.ProjectionGrammar G

  field
    -- The carrier the learner sees during training
    TrainingCarrier : Set

    -- The loss surface the learner optimises against
    LossSurface     : Set

    -- The learner selects a morphism inside the grammar-generated space
    select : (γ : Grammar) → TrainingCarrier → HomSpace γ

    -- The loss evaluates the selected morphism
    loss   : (γ : Grammar) → HomSpace γ → TrainingCarrier → LossSurface

    -- Guard
    learnerReading : String

open Learner public

canonicalSelect : (γ : ⊤) → ⊤ → ⊤
canonicalSelect _ _ = tt

canonicalLoss : (γ : ⊤) → ⊤ → ⊤ → ⊤
canonicalLoss _ _ _ = tt

canonicalLearner : Learner PG.canonicalProjectionGrammar
canonicalLearner = record
  { TrainingCarrier = ⊤
  ; LossSurface     = ⊤
  ; select          = canonicalSelect
  ; loss            = canonicalLoss
  ; learnerReading  = "Canonical Learner: all types ⊤, selection and loss are trivial."
  }

----------------------------------------------------------------------
-- 2. AuthorityGrammar: grammar-generated morphisms from Carrier to
--    AuthoritySurface.
--
-- Authority is not external to the formalism.  It is another
-- grammar-generated morphism space, symmetrical with the projection
-- grammar.  An assay protocol generates measurement morphisms; a
-- proof checker generates verification morphisms; a benchmark suite
-- generates scoring morphisms.
----------------------------------------------------------------------

record AuthorityGrammar : Set₁ where
  field
    Carrier          : Set
    AuthoritySurface : Set
    AGrammar         : Set
    HomAuthority     : AGrammar → Set
    applyAuthority   : ∀ {γ} → HomAuthority γ → Carrier → AuthoritySurface

    -- Guards
    forbiddenPromotions : List String
    allowedOperations   : List String
    encodingReading     : String

  AuthorityProjection : Set
  AuthorityProjection = Σ AGrammar λ γ → HomAuthority γ

  evalAuthority : AuthorityProjection → Carrier → AuthoritySurface
  evalAuthority (γ , h) = applyAuthority h

open AuthorityGrammar public

-- Every AuthorityGrammar can be viewed as a ProjectionGrammar
authorityAsProjectionGrammar : AuthorityGrammar → PG.ProjectionGrammar
authorityAsProjectionGrammar ag = record
  { Carrier             = Carrier ag
  ; Observable          = AuthoritySurface ag
  ; Grammar             = AGrammar ag
  ; HomSpace            = HomAuthority ag
  ; apply               = λ h x → applyAuthority ag h x
  ; forbiddenPromotions = forbiddenPromotions ag
  ; allowedOperations   = allowedOperations ag
  ; encodingReading     = encodingReading ag
  }

canonicalAuthorityGrammar : AuthorityGrammar
canonicalAuthorityGrammar = record
  { Carrier             = ⊤
  ; AuthoritySurface    = ⊤
  ; AGrammar            = ⊤
  ; HomAuthority        = λ _ → ⊤
  ; applyAuthority      = λ _ _ → tt
  ; forbiddenPromotions =
      "noAuthorityIndependentClaim" ∷ []
  ; allowedOperations   =
      "authorityGeneratedMeasurement" ∷
      "authorityTransport" ∷ []
  ; encodingReading     =
      "Canonical AuthorityGrammar: all types ⊤, Hom-authority is trivial."
  }

----------------------------------------------------------------------
-- 3. ResidualComparison: compares projection morphisms against
--    authority morphisms.
--
-- A model output is not compared to "truth."  It is compared to an
-- authority morphism generated by another grammar.  The residual
-- measures the gap between the two generated surfaces.
----------------------------------------------------------------------

record ResidualComparison
  (ProjG : PG.ProjectionGrammar)
  (AuthG : AuthorityGrammar)
  : Set₁ where

  field
    -- Bridge from projection carrier to authority carrier
    carrierCoercion : PG.Carrier ProjG → Carrier AuthG

    -- The residual compares a projection (grammar + morphism) against
    -- an authority projection (grammar + morphism)
    residual : PG.Projection ProjG → AuthorityProjection AuthG → Set

    -- Closed: the gap is discharged under the declared comparison
    closed   : PG.Projection ProjG → AuthorityProjection AuthG → Set

    -- Guard
    residualReading : String

open ResidualComparison public

canonicalResidualComparison : ResidualComparison
  PG.canonicalProjectionGrammar canonicalAuthorityGrammar
canonicalResidualComparison = record
  { carrierCoercion  = λ x → x
  ; residual         = λ _ _ → ⊤
  ; closed           = λ _ _ → ⊤
  ; residualReading  = "Canonical ResidualComparison: trivial coercion, residual, and closure."
  }

----------------------------------------------------------------------
-- 4. PromotionGate: promotion is residual closure.
--
--   No authority grammar → no authority morphism.
--   No residual comparison → no promotion.
--   No closure proof → candidate only.
--
--   Every DASHI encoding is fail-closed: without a closure proof,
--   the promotion flag stays false.
----------------------------------------------------------------------

record PromotionGate
  (ProjG : PG.ProjectionGrammar)
  (AuthG : AuthorityGrammar)
  (RC : ResidualComparison ProjG AuthG)
  : Set₁ where

  field
    -- Promoted: the claim that a projection is authority-supported
    Promoted : PG.Projection ProjG → AuthorityProjection AuthG → Set

    -- promote constructs a promotion proof from residual + closure
    promote  : (π : PG.Projection ProjG)
             → (α : AuthorityProjection AuthG)
             → ResidualComparison.residual RC π α
             → ResidualComparison.closed RC π α
             → Promoted π α

    -- Fail-closed: without residual and closure, no promotion
    failClosed : ∀ (π : PG.Projection ProjG)
                → (α : AuthorityProjection AuthG)
                → Promoted π α
                → Σ (ResidualComparison.residual RC π α) λ _ → ResidualComparison.closed RC π α

    -- Guard
    gateReading : String

open PromotionGate public

canonicalPromotionGate : PromotionGate
  PG.canonicalProjectionGrammar canonicalAuthorityGrammar
  canonicalResidualComparison
canonicalPromotionGate = record
  { Promoted    = λ _ _ → ⊤
  ; promote     = λ _ _ _ _ → tt
  ; failClosed  = λ _ _ _ → tt , tt
  ; gateReading =
      "Canonical PromotionGate: trivial promotion, residual + closure always satisfied."
  }

----------------------------------------------------------------------
-- 5. Full NS-AI pipeline assembly
----------------------------------------------------------------------

record NSAIPipeline
  (ProjG : PG.ProjectionGrammar)
  (AuthG : AuthorityGrammar)
  : Set₁ where

  field
    learner          : Learner ProjG
    comparison       : ResidualComparison ProjG AuthG
    gate             : PromotionGate ProjG AuthG comparison

  open Learner          learner
  open ResidualComparison comparison
  open PromotionGate    gate

  pipelineReading : String
  pipelineReading =
    "NSAI Pipeline: projection grammar generates Hom-space; learner selects morphism; authority grammar generates reference; residual comparison measures gap; promotion requires closure."

open NSAIPipeline public

canonicalNSAIPipeline : NSAIPipeline
  PG.canonicalProjectionGrammar canonicalAuthorityGrammar
canonicalNSAIPipeline = record
  { learner    = canonicalLearner
  ; comparison = canonicalResidualComparison
  ; gate       = canonicalPromotionGate
  }
