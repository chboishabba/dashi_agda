chainDepthInvariant rotateXZY past yNow = refl
chainDepthInvariant rotateXZY past zNow = refl
chainDepthInvariant rotateXZY past future = refl
chainDepthInvariant rotateXZY xNow past = refl
chainDepthInvariant rotateXZY xNow xNow = refl
chainDepthInvariant rotateXZY xNow yNow = refl
chainDepthInvariant rotateXZY xNow zNow = refl
chainDepthInvariant rotateXZY xNow future = refl
chainDepthInvariant rotateXZY yNow past = refl
chainDepthInvariant rotateXZY yNow xNow = refl
chainDepthInvariant rotateXZY yNow yNow = refl
chainDepthInvariant rotateXZY yNow zNow = refl
chainDepthInvariant rotateXZY yNow future = refl
chainDepthInvariant rotateXZY zNow past = refl
chainDepthInvariant rotateXZY zNow xNow = refl
chainDepthInvariant rotateXZY zNow yNow = refl
chainDepthInvariant rotateXZY zNow zNow = refl
chainDepthInvariant rotateXZY zNow future = refl
chainDepthInvariant rotateXZY future past = refl
chainDepthInvariant rotateXZY future xNow = refl
chainDepthInvariant rotateXZY future yNow = refl
chainDepthInvariant rotateXZY future zNow = refl
chainDepthInvariant rotateXZY future future = refl

