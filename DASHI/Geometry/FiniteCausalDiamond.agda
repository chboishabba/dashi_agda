------------------------------------------------------------------------
-- Finite causal classification.  Adjacent causal links are null; the full
-- past-to-future relation is timelike; incomparable slice pairs are spacelike.


data IntervalClass : Set where
  timelikeInterval : IntervalClass
  nullInterval : IntervalClass
  spacelikeInterval : IntervalClass

interval : Event → Event → IntervalClass
interval past xNow = nullInterval
interval past yNow = nullInterval
interval past zNow = nullInterval
interval xNow future = nullInterval
interval yNow future = nullInterval
interval zNow future = nullInterval
interval past future = timelikeInterval
interval _ _ = spacelikeInterval


data Null : IntervalClass → Set where
  isNull : Null nullInterval


data CausalEdge : Event → Event → Set where
  edge-past-x : CausalEdge past xNow
  edge-past-y : CausalEdge past yNow
  edge-past-z : CausalEdge past zNow
  edge-x-future : CausalEdge xNow future
  edge-y-future : CausalEdge yNow future
  edge-z-future : CausalEdge zNow future

nullImpliesCausalEdge :
  (a b : Event) → Null (interval a b) → CausalEdge a b
nullImpliesCausalEdge past xNow isNull = edge-past-x
nullImpliesCausalEdge past yNow isNull = edge-past-y
nullImpliesCausalEdge past zNow isNull = edge-past-z
nullImpliesCausalEdge xNow future isNull = edge-x-future
nullImpliesCausalEdge yNow future isNull = edge-y-future
nullImpliesCausalEdge zNow future isNull = edge-z-future

spatialDimension : Nat
spatialDimension = 3

spatialDimensionIsThree : spatialDimension ≡ 3
spatialDimensionIsThree = refl

timeDimension : Nat
timeDimension = 1

timeDimensionIsOne : timeDimension ≡ 1
timeDimensionIsOne = refl


data FiniteSignatureUnique : Set where
  finiteSignatureUnique : FiniteSignatureUnique

finiteCausalDiamondProof : ChainAntichainLorentzProof
finiteCausalDiamondProof =
  record
    { Event = Event
    ; CausalRelated = _≺_
    ; Chain = Chain
    ; Antichain = SpatialSlice
    ; Separates = Separates
    ; chainDepth = chainDepth
    ; antichainWidth = antichainWidth
    ; PosetIsomorphism = SpatialRotation
    ; transportEvent = transportEvent
    ; chainDepthInvariant = chainDepthInvariant
    ; antichainWidthInvariant = antichainWidthInvariant
    ; Interval = IntervalClass
    ; interval = interval
    ; Null = Null
    ; finiteSpeedCone = λ a b _ → CausalEdge a b
    ; spatialDimension = spatialDimension
    ; spatialDimensionIsThree = spatialDimensionIsThree
    ; timeDimension = timeDimension
    ; timeDimensionIsOne = timeDimensionIsOne
    ; signatureUnique = FiniteSignatureUnique
    }
