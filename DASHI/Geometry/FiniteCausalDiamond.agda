module DASHI.Geometry.FiniteCausalDiamond where

open import Agda.Builtin.Equality using (_≡_; refl)
open import Agda.Builtin.Nat using (Nat; zero; suc)

open import DASHI.Unified.GRQuantumProofTerms

------------------------------------------------------------------------
-- Exact finite causal diamond.
--
-- This module gives a proposition-level model for the chain/antichain API:
-- one past event, a three-element mutually incomparable spatial slice, and one
-- future event.  It proves invariance under a cyclic spatial relabelling and
-- exposes adjacent causal links as the finite null boundary.  It is a checked
-- finite model, not a continuum-limit or physical-dimension uniqueness proof.


data Event : Set where
  past : Event
  xNow : Event
  yNow : Event
  zNow : Event
  future : Event

infix 4 _≺_
data _≺_ : Event → Event → Set where
  past-x : past ≺ xNow
  past-y : past ≺ yNow
  past-z : past ≺ zNow
  x-future : xNow ≺ future
  y-future : yNow ≺ future
  z-future : zNow ≺ future
  past-future : past ≺ future

-- Explicit length-two chains through the spatial slice.
data Chain : Event → Event → Set where
  chain-via-x : Chain past future
  chain-via-y : Chain past future
  chain-via-z : Chain past future
  chain-past-x : Chain past xNow
  chain-past-y : Chain past yNow
  chain-past-z : Chain past zNow
  chain-x-future : Chain xNow future
  chain-y-future : Chain yNow future
  chain-z-future : Chain zNow future


data SpatialSlice : Set where
  xyzSlice : SpatialSlice


data Separates : SpatialSlice → Event → Event → Set where
  xyz-separates-past-future : Separates xyzSlice past future


data Incomparable : Event → Event → Set where
  x-y-incomparable : Incomparable xNow yNow
  x-z-incomparable : Incomparable xNow zNow
  y-x-incomparable : Incomparable yNow xNow
  y-z-incomparable : Incomparable yNow zNow
  z-x-incomparable : Incomparable zNow xNow
  z-y-incomparable : Incomparable zNow yNow

chainDepth : Event → Event → Nat
chainDepth past future = 2
chainDepth past xNow = 1
chainDepth past yNow = 1
chainDepth past zNow = 1
chainDepth xNow future = 1
chainDepth yNow future = 1
chainDepth zNow future = 1
chainDepth _ _ = 0

antichainWidth : Event → Event → Nat
antichainWidth past future = 3
antichainWidth xNow yNow = 2
antichainWidth xNow zNow = 2
antichainWidth yNow xNow = 2
antichainWidth yNow zNow = 2
antichainWidth zNow xNow = 2
antichainWidth zNow yNow = 2
antichainWidth _ _ = 0

------------------------------------------------------------------------
-- Poset automorphism generated by cyclic rotation of the spatial slice.


data SpatialRotation : Set where
  identityRotation : SpatialRotation
  rotateXYZ : SpatialRotation
  rotateXZY : SpatialRotation

transportEvent : SpatialRotation → Event → Event
transportEvent identityRotation event = event
transportEvent rotateXYZ past = past
transportEvent rotateXYZ xNow = yNow
transportEvent rotateXYZ yNow = zNow
transportEvent rotateXYZ zNow = xNow
transportEvent rotateXYZ future = future
transportEvent rotateXZY past = past
transportEvent rotateXZY xNow = zNow
transportEvent rotateXZY yNow = xNow
transportEvent rotateXZY zNow = yNow
transportEvent rotateXZY future = future

chainDepthInvariant :
  (rotation : SpatialRotation) (a b : Event) →
  chainDepth (transportEvent rotation a) (transportEvent rotation b)
  ≡ chainDepth a b
chainDepthInvariant identityRotation a b = refl
chainDepthInvariant rotateXYZ past past = refl
chainDepthInvariant rotateXYZ past xNow = refl
chainDepthInvariant rotateXYZ past yNow = refl
chainDepthInvariant rotateXYZ past zNow = refl
chainDepthInvariant rotateXYZ past future = refl
