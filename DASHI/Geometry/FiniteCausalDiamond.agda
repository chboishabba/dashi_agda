  antichainWidth (transportEvent rotation a) (transportEvent rotation b)
  ≡ antichainWidth a b
antichainWidthInvariant identityRotation a b = refl
antichainWidthInvariant rotateXYZ past past = refl
antichainWidthInvariant rotateXYZ past xNow = refl
antichainWidthInvariant rotateXYZ past yNow = refl
antichainWidthInvariant rotateXYZ past zNow = refl
antichainWidthInvariant rotateXYZ past future = refl
antichainWidthInvariant rotateXYZ xNow past = refl
antichainWidthInvariant rotateXYZ xNow xNow = refl
antichainWidthInvariant rotateXYZ xNow yNow = refl
antichainWidthInvariant rotateXYZ xNow zNow = refl
