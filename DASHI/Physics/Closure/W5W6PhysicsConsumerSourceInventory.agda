record W5W6PhysicsConsumerSourceInventory : Setω where
  field
    sourcePackageExists :
      Bool

    currentStatus :
      W5W6PhysicsConsumerInventoryStatus

    w5ClosurePromotionRequestPack :
      W5Pack.GRQFTClosurePromotionReceiptRequestPack

    w5AuthorityCollation :
      Authority.HEPDataEmpiricalAuthorityReceiptCollation

    w5HighMassSources :
      List W5HighMassGRQFTConsumerSource

    w5HighMassSourcesAreCanonical :
      w5HighMassSources
      ≡
      canonicalW5HighMassGRQFTConsumerSources

    w5HighMassSourceLabels :
      List String

    w5HighMassSourceLabelsAreCanonical :
      w5HighMassSourceLabels
      ≡
      canonicalW5HighMassGRQFTConsumerSourceLabels

    fullTableMapSummary :
      List String

    fullTableMapSummaryIsCanonical :
      fullTableMapSummary
      ≡
      canonicalW5W6FullTableMapSummary

    w6TheoryAdapterCandidates :
      List W6TheoryComparisonAdapterCandidate

    w6TheoryAdapterCandidatesAreCanonical :
      w6TheoryAdapterCandidates
      ≡
      canonicalW6TheoryComparisonAdapterCandidates

    w6TheoryAdapterCandidateLabels :
      List String

    w6TheoryAdapterCandidateLabelsAreCanonical :
      w6TheoryAdapterCandidateLabels
      ≡
      canonicalW6TheoryComparisonAdapterCandidateLabels

    firstW6TheoryAdapterCandidate :
      W6TheoryComparisonAdapterCandidate

    firstW6TheoryAdapterCandidateIsCASCADEOnly :
      firstW6TheoryAdapterCandidate
      ≡
      cascadeTMDCandidate

    w6ComparisonLawStatus :
      Comparison.HEPDataResidualComparisonLawStatus

    w6ComparisonLawStillBlocked :
      w6ComparisonLawStatus
      ≡
      Comparison.blockedAwaitingResidualComparisonLawReceipts

    w6AdapterDiagnostic :
      Adapter.HEPDataITIRAuthorityAdapterDiagnostic

    w6AcceptedITIRAdapterStillAbsent :
      Adapter.HEPDataITIRAuthorityAdapterDiagnostic.adapterStatus
        w6AdapterDiagnostic
      ≡
      Adapter.genericScaffoldPresentHEPDataAuthorityAdapterAbsent

    missingConsumerReceipts :
      List W5W6PhysicsConsumerInventoryMissingReceipt

    missingConsumerReceiptsAreCanonical :
      missingConsumerReceipts
      ≡
      canonicalW5W6PhysicsConsumerInventoryMissingReceipts

    receiptRequestBoundary :
      List String

    coordinationDiagramDeltasNeeded :
      List String

    indexDeltasNeeded :
      List String

    nonPromotionBoundary :
      List String

    remainingBlockers :
      List String

canonicalW5W6PhysicsConsumerSourceInventory :
  W5W6PhysicsConsumerSourceInventory
canonicalW5W6PhysicsConsumerSourceInventory =
  record
    { sourcePackageExists =
        true
    ; currentStatus =
        sourcePackagePresentConsumersAwaitReceipts
    ; w5ClosurePromotionRequestPack =
        W5Pack.canonicalGRQFTClosurePromotionReceiptRequestPack
    ; w5AuthorityCollation =
        Authority.canonicalHEPDataEmpiricalAuthorityReceiptCollation
    ; w5HighMassSources =
        canonicalW5HighMassGRQFTConsumerSources
    ; w5HighMassSourcesAreCanonical =
        refl
    ; w5HighMassSourceLabels =
        canonicalW5HighMassGRQFTConsumerSourceLabels
    ; w5HighMassSourceLabelsAreCanonical =
        refl
    ; fullTableMapSummary =
        canonicalW5W6FullTableMapSummary
    ; fullTableMapSummaryIsCanonical =
        refl
    ; w6TheoryAdapterCandidates =
        canonicalW6TheoryComparisonAdapterCandidates
    ; w6TheoryAdapterCandidatesAreCanonical =
        refl
    ; w6TheoryAdapterCandidateLabels =
        canonicalW6TheoryComparisonAdapterCandidateLabels
    ; w6TheoryAdapterCandidateLabelsAreCanonical =
        refl
    ; firstW6TheoryAdapterCandidate =
        cascadeTMDCandidate
    ; firstW6TheoryAdapterCandidateIsCASCADEOnly =
        refl
    ; w6ComparisonLawStatus =
        Comparison.blockedAwaitingResidualComparisonLawReceipts
    ; w6ComparisonLawStillBlocked =
        refl
    ; w6AdapterDiagnostic =
        Adapter.canonicalHEPDataITIRAuthorityAdapterDiagnostic
    ; w6AcceptedITIRAdapterStillAbsent =
        refl
    ; missingConsumerReceipts =
        canonicalW5W6PhysicsConsumerInventoryMissingReceipts
    ; missingConsumerReceiptsAreCanonical =
        refl
    ; receiptRequestBoundary =
        "W5 source inventory names phistar high-mass tables t23-t28, ratio tables t45-t50, response matrices t72-t77, and pT secondary tables t1-t18/t51-t67"
        ∷ "W6 source inventory names candidate theory-comparison adapters only, with CASCADE TMD first in the candidate order"
        ∷ "Consumer receipts must still bind DOI, table identity, checksum/source package identity, selected bins/columns, response-matrix semantics, theory-adapter semantics, and comparison-law target"
        ∷ []
    ; coordinationDiagramDeltasNeeded =
        "Add diagram node HEP-R23 / W5-W6 source inventory: DOI 10.17182/hepdata.115656.v1; phistar t23-t28; ratios t45-t50; response t72-t77; pT secondary t1-t18/t51-t67; non-promoting"
        ∷ "Add edge from HEP-R23 to W5: source inventory only, blocked until GRQFTClosurePromotionReceipt and empirical GR/QFT validation"
        ∷ "Add edge from HEP-R23 to W6: CASCADE-first theory-adapter candidate queue only, blocked until adapter selection, residual comparison law, accepted ITIR adapter, and runtime PNF receipts"
        ∷ "Add blocker edge from HEP-R23 to Plateau/Governance: no closure, no empirical validation, no ITIR/PNF runtime promotion"
        ∷ []
    ; indexDeltasNeeded =
        "Import DASHI.Physics.Closure.W5W6PhysicsConsumerSourceInventory in the next shared Agda index pass if W0 wants this surface exported"
        ∷ "Add HEP-R23 row to worker coordination index with owner W5-W6-physics-consumer-inventory and scope DASHI/Physics/Closure/W5W6PhysicsConsumerSourceInventory.agda"
        ∷ "Record validation target: agda DASHI/Physics/Closure/W5W6PhysicsConsumerSourceInventory.agda"
        ∷ "Do not mark W5, W6, GR/QFT closure, ITIR adapter acceptance, or runtime PNF emission as promoted in any index"
        ∷ []
    ; nonPromotionBoundary =
        "This module does not construct GRQFTClosurePromotionReceipt or GRQFTClosurePromotionAuthorityToken"
        ∷ "This module does not construct a GR equation law, QFT interaction law, or consumer law witness"
        ∷ "This module does not claim empirical GR/QFT validation"
        ∷ "This module does not emit PNF at runtime and does not consume PNF runtime receipts"
        ∷ "This module does not construct a residual comparison law"
        ∷ "This module does not construct or accept a HEPData-to-ITIR authority adapter"
        ∷ []
    ; remainingBlockers =
        "W5 remains blocked on external GR/QFT closure-promotion receipt, laws, witnesses, and empirical validation"
        ∷ "W6 remains blocked on theory-adapter selection receipts and a residual-aware comparison-law receipt"
        ∷ "CASCADE TMD is recorded only as the first candidate name, not as an accepted adapter"
        ∷ "The accepted ITIR adapter and runtime PNF emission routes remain outside this source inventory"
        ∷ []
    }

