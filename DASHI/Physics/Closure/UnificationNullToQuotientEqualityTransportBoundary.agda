-- Null-to-quotient transport vocabulary.

record NullToQuotientTransportVocabulary
  (V : U1a.AdmissibleDefectQuotientVBoundary)
  (G-boundary : U1a.GluingOperatorGBoundary V) : Setω where
  field
    nullClass :
      U1a.DefectQuotientV V → Set

    quotientEquivalent :
      U1a.DefectQuotientV V →
      U1a.DefectQuotientV V →
      Set

    moduloNullEqual :
      U1a.DefectQuotientV V →
      U1a.DefectQuotientV V →
      Set

    crossTerm :
      U1a.DefectQuotientV V →
      U1a.DefectQuotientV V →
      U1a.DefectQuotientV V

    nullToZeroStatement :
      String

    nullToZeroStatementIsCanonical :
      nullToZeroStatement
      ≡ "nullClass x -> moduloNullEqual x zeroV"

    moduloLinearityStatement :
      String

    moduloLinearityStatementIsCanonical :
      moduloLinearityStatement
      ≡ "nullClass (crossTerm s1 s2) -> moduloNullEqual (G(s1 +V s2)) (G s1 +V G s2)"

    vocabularyRecorded :
      Bool

    vocabularyRecordedIsTrue :
      vocabularyRecorded ≡ true

open NullToQuotientTransportVocabulary public

