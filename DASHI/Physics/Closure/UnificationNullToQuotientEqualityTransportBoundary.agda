record NullToQuotientTransportTargetRow : Set where
  field
    stage :
      NullToQuotientTransportStage

    status :
      NullToQuotientTransportStatus

    statusIsCanonical :
      status ≡ canonicalNullToQuotientTransportStatus stage

    blocker :
      NullToQuotientTransportBlocker

    blockerIsCanonical :
      blocker ≡ canonicalNullToQuotientTransportBlocker stage

    proofContract :
      String

    consumer :
      String

    provedHere :
      Bool

    provedHereIsFalse :
      provedHere ≡ false

open NullToQuotientTransportTargetRow public

mkNullToQuotientTransportTargetRow :
  NullToQuotientTransportStage →
  String →
  String →
  NullToQuotientTransportTargetRow
mkNullToQuotientTransportTargetRow stage proofContract consumer =
  record
    { stage =
        stage
    ; status =
        canonicalNullToQuotientTransportStatus stage
    ; statusIsCanonical =
        refl
    ; blocker =
        canonicalNullToQuotientTransportBlocker stage
    ; blockerIsCanonical =
        refl
    ; proofContract =
        proofContract
    ; consumer =
        consumer
    ; provedHere =
        false
    ; provedHereIsFalse =
        refl
    }

canonicalNullToQuotientTransportTargetRows :
  List NullToQuotientTransportTargetRow
canonicalNullToQuotientTransportTargetRows =
  mkNullToQuotientTransportTargetRow
    u1aQuotientImported
    "import admissible defect quotient V, zeroV, +V, scalar action, and G"
    "GluingOperatorLinearityOnDefectQuotientBoundary"
  ∷ mkNullToQuotientTransportTargetRow
    nullClassStabilityImported
    "import null-class stability child boundary and keep all stability gates false"
    "UnificationNullClassStabilityBoundary"
  ∷ mkNullToQuotientTransportTargetRow
    crossTermNullityImported
    "import cross-term nullity parent boundary and keep nullity theorem false"
    "UnificationGluingCrossTermNullClassBoundary"
  ∷ mkNullToQuotientTransportTargetRow
    linearityLiftImported
    "import cross-term-to-linearity lift and isolate its missing transport blocker"
    "UnificationGluingCrossTermLinearityLiftBoundary"
  ∷ mkNullToQuotientTransportTargetRow
    nullPredicateVocabulary
    "record nullClass : V -> Set as the semantic zero-residual predicate"
    "null-to-zero bridge"
  ∷ mkNullToQuotientTransportTargetRow
    quotientEquivalenceVocabulary
    "record quotientEquivalent and moduloNullEqual relations"
    "representative invariant quotient equality"
  ∷ mkNullToQuotientTransportTargetRow
    nullToZeroBridge
    "prove nullClass x transports to moduloNullEqual x zeroV"
    "cross-term nullity to modulo-linearity"
  ∷ mkNullToQuotientTransportTargetRow
    representativeInvariance
    "prove quotientEquivalent x y transports nullClass x, moduloNullEqual x z, and crossTerm expressions"
    "well-defined quotient equality"
  ∷ mkNullToQuotientTransportTargetRow
    quotientOperationCongruence
    "prove moduloNullEqual is a congruence for +V, additive inverse, and scalar action"
    "modulo-null algebra"
  ∷ mkNullToQuotientTransportTargetRow
    gluingOperatorCongruence
    "prove moduloNullEqual x y implies moduloNullEqual (G x) (G y)"
    "G-linearity modulo null"
  ∷ mkNullToQuotientTransportTargetRow
    crossTermNullToModuloLinearity
    "transport nullClass (crossTerm s1 s2) into moduloNullEqual (G(s1+s2)) (Gs1+Gs2)"
    "UnificationGluingCrossTermLinearityLiftBoundary"
  ∷ mkNullToQuotientTransportTargetRow
    trueQuotientLinearityConsumer
    "consume modulo-null equality only after null representatives collapse to quotient equality"
    "GluingOperatorLinearityOnDefectQuotientBoundary"
  ∷ mkNullToQuotientTransportTargetRow
    fourPointCancellationConsumer
    "transport quotient linearity into the four-point functional and cancel the gluing residual"
    "UnificationCrossTermToFourPointCompositeBoundary"
  ∷ mkNullToQuotientTransportTargetRow
    parallelogramConsumer
    "derive parallelogram only after four-point cancellation is proved"
    "UnificationCrossTermToFourPointCompositeBoundary"
  ∷ mkNullToQuotientTransportTargetRow
    quadraticEmergenceConsumer
    "derive quadratic emergence only after parallelogram"
    "UnificationCrossTermToFourPointCompositeBoundary"
  ∷ mkNullToQuotientTransportTargetRow
    terminalPromotionGate
    "hold terminal unification and Clay promotion"
    "all imported promotion gates"
  ∷ []

canonicalNullToQuotientTransportTargetRowCount : Nat
canonicalNullToQuotientTransportTargetRowCount =
  listLength canonicalNullToQuotientTransportTargetRows

canonicalNullToQuotientTransportTargetRowCountIs16 :
  canonicalNullToQuotientTransportTargetRowCount ≡ 16
canonicalNullToQuotientTransportTargetRowCountIs16 =
  refl

