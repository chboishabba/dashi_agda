  record
    { status =
        p2LaneInnerProductBridgeRecorded
    ; lane =
        p2
    ; laneIsP2 =
        refl
    ; laneCardinality =
        toNat p2
    ; laneCardinalityIsTwo =
        refl
    ; baseFieldCardinality =
        2
    ; baseFieldCardinalityIsF2 =
        refl
    ; extensionFieldCardinality =
        4
    ; extensionFieldCardinalityIsF4 =
        refl
    ; extensionDegree =
        2
    ; extensionDegreeIsTwo =
        refl
    ; galoisGroupOrder =
        2
    ; galoisGroupOrderIsTwo =
        refl
    ; frobeniusOrder =
        2
    ; frobeniusOrderIsTwo =
        refl
    ; finiteLaneLabel =
        p2FiniteLaneLabel
    ; finiteLaneLabelIsCanonical =
        refl
    ; frobeniusLaneLabel =
        p2FrobeniusLaneLabel
    ; frobeniusLaneLabelIsCanonical =
        refl
    ; galF4F2IdentifiedWithC2 =
        true
    ; galF4F2IdentifiedWithC2IsTrue =
        refl
    ; cmJInvariant =
        1728
    ; cmJInvariantIs1728 =
        refl
    ; cmConductorLevel =
        4
    ; cmConductorLevelIsFour =
        refl
    ; x0Level =
        4
    ; x0LevelIsFour =
        refl
    ; endomorphismRing =
        "Z[i]"
    ; endomorphismRingIsGaussianIntegers =
        refl
    ; cmOrbitLabel =
        p2CMOrbitLabel
    ; cmOrbitLabelIsCanonical =
        refl
    ; cmOrbitAuthorityBacked =
        true
    ; cmOrbitAuthorityBackedIsTrue =
        refl
    ; eichlerShimuraBridgeAuthorityLabel =
        p2EichlerShimuraAuthorityLabel
    ; eichlerShimuraBridgeAuthorityLabelIsCanonical =
        refl
    ; eichlerShimuraStepAuthorityBacked =
        true
    ; eichlerShimuraStepAuthorityBackedIsTrue =
        refl
    ; eichlerShimuraFormalProofConstructed =
        false
    ; eichlerShimuraFormalProofConstructedIsFalse =
        refl
    ; innerProductCarrier =
        p2InnerProductCarrierLabel
    ; innerProductCarrierIsCanonical =
        refl
    ; boundedCarrierProof =
        true
    ; boundedCarrierProofIsTrue =
        refl
    ; physicalCKMOperatorConstructed =
        false
    ; physicalCKMOperatorConstructedIsFalse =
        refl
    ; cabibboPromotionConstructed =
        false
    ; cabibboPromotionConstructedIsFalse =
