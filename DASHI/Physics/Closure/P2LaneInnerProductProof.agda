p2LaneInnerProductRecordsGaussianCMLevelFour =
  refl

p2LaneInnerProductRecordsAuthorityBackedEichlerShimuraStep :
  eichlerShimuraStepAuthorityBacked canonicalP2LaneInnerProductProofReceipt
  ≡
  true
p2LaneInnerProductRecordsAuthorityBackedEichlerShimuraStep =
  refl

p2LaneInnerProductDoesNotPromoteFormalEichlerShimuraProof :
  eichlerShimuraFormalProofConstructed canonicalP2LaneInnerProductProofReceipt
  ≡
  false
p2LaneInnerProductDoesNotPromoteFormalEichlerShimuraProof =
  refl

p2LaneInnerProductDoesNotConstructPhysicalCKMOperator :
  physicalCKMOperatorConstructed canonicalP2LaneInnerProductProofReceipt
