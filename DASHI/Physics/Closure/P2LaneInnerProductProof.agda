    ; derivationSteps =
        canonicalP2LaneInnerProductSteps
    ; derivationStepsAreCanonical =
        refl
    ; blockers =
        canonicalP2LaneInnerProductBlockers
    ; blockersAreCanonical =
        refl
    ; receiptBoundary =
        "The finite p2 carrier is F4/F2 with Frobenius x |-> x^2 and Gal(F4/F2)=C2"
        ∷ "The CM orbit is recorded as the j=1728, End(E)=Z[i], conductor-four lane"
        ∷ "The p2 inner product is carried as the X0(4) hyperbolic L2 inner product"
        ∷ "The Eichler-Shimura/CM modular step is authority-backed and not formalized in this file"
        ∷ "No full Eichler-Shimura proof, physical CKM operator, or Cabibbo promotion is constructed here"
        ∷ []
    }

data P2FullEichlerShimuraProofPromoted : Set where

p2FullEichlerShimuraProofPromotedIsFalse :
  P2FullEichlerShimuraProofPromoted →
  ⊥
p2FullEichlerShimuraProofPromotedIsFalse ()

p2LaneInnerProductRecordsF4F2 :
  extensionFieldCardinality canonicalP2LaneInnerProductProofReceipt
  ≡
  4
p2LaneInnerProductRecordsF4F2 =
  refl

