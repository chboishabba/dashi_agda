------------------------------------------------------------------------
-- Atomic-clock SI second as a real-time/topology request.
--
-- This module is intentionally a request surface, not a Real construction.
-- It threads the local Cs-133 SI-second calibration bridge into the Stone
-- SI-second time-parameter bridge and records exactly what a later physical
-- Real carrier/topology provider must supply before Stone strong continuity
-- can be promoted from the finite receipt to a physical one-parameter group.

data RealTimeTopologyRequestStatus : Set where
  siSecondRecordedAwaitingRealCarrierMetricTopologyAndDomain :
    RealTimeTopologyRequestStatus

data RealTimeTopologyRequirement : Set where
  requireRealLineCarrier :
    RealTimeTopologyRequirement

  requireMetricCompatibleWithSISecondScale :
    RealTimeTopologyRequirement

  requireTopologyGeneratedByMetric :
    RealTimeTopologyRequirement

  requireContinuousAdditiveTimeGroup :
    RealTimeTopologyRequirement

  requireStrongOperatorTopology :
    RealTimeTopologyRequirement

  requireStoneStrongContinuityLaw :
    RealTimeTopologyRequirement

  requireSelfAdjointGeneratorDomain :
    RealTimeTopologyRequirement

  requireHbarHamiltonianDimensionalCancellation :
    RealTimeTopologyRequirement

canonicalRealTimeTopologyRequirements :
  List RealTimeTopologyRequirement
canonicalRealTimeTopologyRequirements =
  requireRealLineCarrier
  ∷ requireMetricCompatibleWithSISecondScale
  ∷ requireTopologyGeneratedByMetric
  ∷ requireContinuousAdditiveTimeGroup
  ∷ requireStrongOperatorTopology
  ∷ requireStoneStrongContinuityLaw
  ∷ requireSelfAdjointGeneratorDomain
  ∷ requireHbarHamiltonianDimensionalCancellation
  ∷ []

