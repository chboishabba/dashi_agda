    siSecondEmbeddingSupplied :
      Bool

    siSecondEmbeddingSuppliedIsFalse :
      siSecondEmbeddingSupplied ≡ false

    parameterName :
      String

    parameterNameIsCanonical :
      parameterName ≡ "physical Real-time parameter t measured in SI seconds"

    metricTopologyNarrative :
      List String

