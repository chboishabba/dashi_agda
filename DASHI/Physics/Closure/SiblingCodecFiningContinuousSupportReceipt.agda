    statusIsRecordedNoPromotion :
      status ≡ siblingCodecFiningContinuousSupportRecordedNoPromotion

    local369Receipt :
      Local369.LocalDocs369UnificationSupportReceipt

    local369NoContinuumTheorem :
      Local369.LocalDocs369UnificationSupportReceipt.voxel369ContinuumTheorem
        local369Receipt
      ≡ false

    local369NoClay :
      Local369.LocalDocs369UnificationSupportReceipt.clayPromotion
        local369Receipt
      ≡ false

    codecAtomReceipt :
      Codec.CanonicalCodecAtomReceipt

    codecAtomFieldsCanonical :
      Codec.CanonicalCodecAtomReceipt.atomFields
        codecAtomReceipt
      ≡ Codec.canonicalAtomFields

    codecAtomGate3Open :
      Codec.CanonicalCodecAtomReceipt.gate3DensityProved
        codecAtomReceipt
      ≡ false

    codecAtomMDLOptimalityOpen :
      Codec.CanonicalCodecAtomReceipt.mdlAtomSelectionProvedOptimal
        codecAtomReceipt
      ≡ false

    codecAtomNoClay :
      Codec.CanonicalCodecAtomReceipt.clayPromotionMade
        codecAtomReceipt
      ≡ false

    artifacts :
      List SiblingCodecArtifact

    artifactsAreCanonical :
      artifacts ≡ canonicalSiblingCodecArtifacts

    transforms :
      List SiblingCodecTransform

    transformsAreCanonical :
      transforms ≡ canonicalSiblingCodecTransforms

    runtimeFields :
      List CodecRuntimeField

    runtimeFieldsAreCanonical :
      runtimeFields ≡ canonicalRuntimeFields

    sixFiningLayers :
      List FiningLayer

    sixFiningLayersAreCanonical :
      sixFiningLayers ≡ canonicalSixFiningLayers

    continuousSurfaces :
      List ContinuousSupportSurface

    continuousSurfacesAreCanonical :
      continuousSurfaces ≡ canonicalContinuousSupportSurfaces

    inclusionRules :
      List SiblingCodecInclusionRule

    inclusionRulesAreCanonical :
      inclusionRules ≡ canonicalSiblingCodecInclusionRules

    forbiddenPromotions :
      List ForbiddenSiblingCodecPromotion

    forbiddenPromotionsAreCanonical :
      forbiddenPromotions ≡ canonicalForbiddenSiblingCodecPromotions

    supportIncluded :
      Bool

    supportIncludedIsTrue :
      supportIncluded ≡ true

    productionCodecClaim :
      Bool

    productionCodecClaimIsFalse :
      productionCodecClaim ≡ false

    continuumTheoremClaim :
      Bool

    continuumTheoremClaimIsFalse :
      continuumTheoremClaim ≡ false

    gate3DensityClaim :
      Bool

    gate3DensityClaimIsFalse :
      gate3DensityClaim ≡ false

    nsTheoremPromotion :
      Bool

    nsTheoremPromotionIsFalse :
      nsTheoremPromotion ≡ false

    ymTheoremPromotion :
      Bool

    ymTheoremPromotionIsFalse :
      ymTheoremPromotion ≡ false

    clayPromotion :
      Bool

    clayPromotionIsFalse :
      clayPromotion ≡ false

    codecSummary :
      String

    codecSummaryIsCanonical :
      codecSummary ≡ codecThreadSummary

    finingLayerSummary :
      String

    finingLayerSummaryIsCanonical :
      finingLayerSummary ≡ finingSummary

    continuousScaleSummary :
      String

    continuousScaleSummaryIsCanonical :
      continuousScaleSummary ≡ continuousSummary

    boundary :
      String

    boundaryIsCanonical :
      boundary ≡ boundarySummary

    promotionFlags :
      List SiblingCodecPromotion

    promotionFlagsAreEmpty :
      promotionFlags ≡ []

