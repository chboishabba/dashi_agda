module DASHI.Physics.QFT.DiracSpinSectorReceipt where

open import Agda.Primitive using (Setω)
open import Agda.Builtin.Bool using (Bool; false; true)
open import Agda.Builtin.Equality using (_≡_; refl)
open import Agda.Builtin.Nat using (Nat)
open import Agda.Builtin.String using (String)
open import Data.Empty using (⊥)
open import Data.List.Base using (List; _∷_; [])

------------------------------------------------------------------------
-- Dirac/spin DHR-sector candidate receipt.
--
-- This module records a formal candidate for rho_spin generated by a
-- depth-1 field operator psi.  The candidate is fermionic by construction
-- because its statistics label is CAR-style anticommutation.  It deliberately
-- does not derive the sector from the carrier, prove DHR localization or
-- transportability, construct a full field algebra, or promote the candidate.

data DiracSpinSectorStatus : Set where
  conditionalCandidateOnlyNoPromotion :
    DiracSpinSectorStatus

data DiracSpinFieldOperator : Set where
  psi :
    DiracSpinFieldOperator

data DiracSpinStatisticsLabel : Set where
  carStyleAnticommutation :
    DiracSpinStatisticsLabel

data DiracSpinSectorBlocker : Set where
  missingCarrierDerivation :
    DiracSpinSectorBlocker

  missingDHRLocalizationProof :
    DiracSpinSectorBlocker

  missingDHRTransportabilityProof :
    DiracSpinSectorBlocker

  missingObservableAlgebraEndomorphismAction :
    DiracSpinSectorBlocker

  missingFullFieldAlgebraConstruction :
    DiracSpinSectorBlocker

canonicalDiracSpinSectorBlockers :
  List DiracSpinSectorBlocker
canonicalDiracSpinSectorBlockers =
  missingCarrierDerivation
  ∷ missingDHRLocalizationProof
  ∷ missingDHRTransportabilityProof
  ∷ missingObservableAlgebraEndomorphismAction
  ∷ missingFullFieldAlgebraConstruction
  ∷ []

data DiracSpinSectorPromotionFlag : Set where

diracSpinSectorPromotionFlagImpossibleHere :
  DiracSpinSectorPromotionFlag →
  ⊥
diracSpinSectorPromotionFlagImpossibleHere ()

rhoSpinLabel : String
rhoSpinLabel =
  "rho_spin"

psiDepthOneFieldOperatorLabel : String
psiDepthOneFieldOperatorLabel =
  "psi depth-1 field operator"

carAnticommutationRelationLabel : String
carAnticommutationRelationLabel =
  "CAR-style anticommutation label for psi"

fermionicConstructionLabel : String
fermionicConstructionLabel =
  "rho_spin is fermionic by construction from the CAR-style psi label"

carrierBoundaryLabel : String
carrierBoundaryLabel =
  "howToBuildFromCarrierOpen = true; derivationFromCarrier = false"

record DiracSpinSectorReceipt : Setω where
  field
    sectorName :
      String

    sectorNameIsRhoSpin :
      sectorName ≡ rhoSpinLabel

    status :
      DiracSpinSectorStatus

    statusIsConditionalCandidateOnly :
      status ≡ conditionalCandidateOnlyNoPromotion

    generatingFieldOperator :
      DiracSpinFieldOperator

    generatingFieldOperatorIsPsi :
      generatingFieldOperator ≡ psi

    generatingFieldDepth :
      Nat

    generatingFieldDepthIsOne :
      generatingFieldDepth ≡ 1

    fieldOperatorLabel :
      String

    fieldOperatorLabelIsCanonical :
      fieldOperatorLabel ≡ psiDepthOneFieldOperatorLabel

    statisticsLabel :
      DiracSpinStatisticsLabel

    statisticsLabelIsCARStyle :
      statisticsLabel ≡ carStyleAnticommutation

    anticommutationLabel :
      String

    anticommutationLabelIsCanonical :
      anticommutationLabel ≡ carAnticommutationRelationLabel

    fermionicByConstruction :
      Bool

    fermionicByConstructionIsTrue :
      fermionicByConstruction ≡ true

    fermionicConstruction :
      String

    fermionicConstructionIsCanonical :
      fermionicConstruction ≡ fermionicConstructionLabel

    howToBuildFromCarrierOpen :
      Bool

    howToBuildFromCarrierOpenIsTrue :
      howToBuildFromCarrierOpen ≡ true

    derivationFromCarrier :
      Bool

    derivationFromCarrierIsFalse :
      derivationFromCarrier ≡ false

    carrierBoundary :
      String

    carrierBoundaryIsCanonical :
      carrierBoundary ≡ carrierBoundaryLabel

    dhrLocalizationProved :
      Bool

    dhrLocalizationProvedIsFalse :
      dhrLocalizationProved ≡ false

    dhrTransportabilityProved :
      Bool

    dhrTransportabilityProvedIsFalse :
      dhrTransportabilityProved ≡ false

    observableAlgebraEndomorphismActionConstructed :
      Bool

    observableAlgebraEndomorphismActionConstructedIsFalse :
      observableAlgebraEndomorphismActionConstructed ≡ false

    fullFieldAlgebraConstructed :
      Bool

    fullFieldAlgebraConstructedIsFalse :
      fullFieldAlgebraConstructed ≡ false

    fullPromotion :
      Bool

    fullPromotionIsFalse :
      fullPromotion ≡ false

    promotionFlags :
      List DiracSpinSectorPromotionFlag

    promotionFlagsAreEmpty :
      promotionFlags ≡ []

    blockers :
      List DiracSpinSectorBlocker

    blockersAreCanonical :
      blockers ≡ canonicalDiracSpinSectorBlockers

    receiptBoundary :
      List String

open DiracSpinSectorReceipt public

canonicalDiracSpinSectorReceipt :
  DiracSpinSectorReceipt
canonicalDiracSpinSectorReceipt =
  record
    { sectorName =
        rhoSpinLabel
    ; sectorNameIsRhoSpin =
        refl
    ; status =
        conditionalCandidateOnlyNoPromotion
    ; statusIsConditionalCandidateOnly =
        refl
    ; generatingFieldOperator =
        psi
    ; generatingFieldOperatorIsPsi =
        refl
    ; generatingFieldDepth =
        1
    ; generatingFieldDepthIsOne =
        refl
    ; fieldOperatorLabel =
        psiDepthOneFieldOperatorLabel
    ; fieldOperatorLabelIsCanonical =
        refl
    ; statisticsLabel =
        carStyleAnticommutation
    ; statisticsLabelIsCARStyle =
        refl
    ; anticommutationLabel =
        carAnticommutationRelationLabel
    ; anticommutationLabelIsCanonical =
        refl
    ; fermionicByConstruction =
        true
    ; fermionicByConstructionIsTrue =
        refl
    ; fermionicConstruction =
        fermionicConstructionLabel
    ; fermionicConstructionIsCanonical =
        refl
    ; howToBuildFromCarrierOpen =
        true
    ; howToBuildFromCarrierOpenIsTrue =
        refl
    ; derivationFromCarrier =
        false
    ; derivationFromCarrierIsFalse =
        refl
    ; carrierBoundary =
        carrierBoundaryLabel
    ; carrierBoundaryIsCanonical =
        refl
    ; dhrLocalizationProved =
        false
    ; dhrLocalizationProvedIsFalse =
        refl
    ; dhrTransportabilityProved =
        false
    ; dhrTransportabilityProvedIsFalse =
        refl
    ; observableAlgebraEndomorphismActionConstructed =
        false
    ; observableAlgebraEndomorphismActionConstructedIsFalse =
        refl
    ; fullFieldAlgebraConstructed =
        false
    ; fullFieldAlgebraConstructedIsFalse =
        refl
    ; fullPromotion =
        false
    ; fullPromotionIsFalse =
        refl
    ; promotionFlags =
        []
    ; promotionFlagsAreEmpty =
        refl
    ; blockers =
        canonicalDiracSpinSectorBlockers
    ; blockersAreCanonical =
        refl
    ; receiptBoundary =
        "rho_spin is recorded only as a conditional DHR-sector candidate"
        ∷ "The generating operator is psi at depth 1 with a CAR-style anticommutation statistics label"
        ∷ "The candidate is fermionic by construction, but carrier derivation remains open and false here"
        ∷ "No DHR localization, transportability, observable-algebra endomorphism action, full field algebra, or full promotion is claimed"
        ∷ []
    }

diracSpinSectorIsFermionicByConstruction :
  DiracSpinSectorReceipt.fermionicByConstruction
    canonicalDiracSpinSectorReceipt
  ≡
  true
diracSpinSectorIsFermionicByConstruction =
  DiracSpinSectorReceipt.fermionicByConstructionIsTrue
    canonicalDiracSpinSectorReceipt

diracSpinSectorCarrierDerivationIsOpen :
  DiracSpinSectorReceipt.howToBuildFromCarrierOpen
    canonicalDiracSpinSectorReceipt
  ≡
  true
diracSpinSectorCarrierDerivationIsOpen =
  DiracSpinSectorReceipt.howToBuildFromCarrierOpenIsTrue
    canonicalDiracSpinSectorReceipt

diracSpinSectorNotDerivedFromCarrierHere :
  DiracSpinSectorReceipt.derivationFromCarrier
    canonicalDiracSpinSectorReceipt
  ≡
  false
diracSpinSectorNotDerivedFromCarrierHere =
  DiracSpinSectorReceipt.derivationFromCarrierIsFalse
    canonicalDiracSpinSectorReceipt

diracSpinSectorNoFullPromotion :
  DiracSpinSectorReceipt.fullPromotion
    canonicalDiracSpinSectorReceipt
  ≡
  false
diracSpinSectorNoFullPromotion =
  DiracSpinSectorReceipt.fullPromotionIsFalse
    canonicalDiracSpinSectorReceipt
