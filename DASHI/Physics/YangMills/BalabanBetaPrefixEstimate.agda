module DASHI.Physics.YangMills.BalabanBetaPrefixEstimate where

-- The analytic RG obstruction, stated against the generated finite-cutoff
-- beta law.  This is deliberately one-sided: negative corrections help the
-- inverse-square budget and must not be paid for by an artificial absolute
-- value estimate.

open import Agda.Builtin.Bool using (false)
open import Agda.Builtin.Equality using (_≡_)
open import Agda.Builtin.String using (String)
open import Data.Nat.Base using (ℕ)
open import Data.Empty using (⊥)

open import DASHI.Foundations.RealAnalysisAxioms using (ℝ)
open import DASHI.Geometry.Gauge.SUNPrimitives using (clayYangMillsPromoted)
open import DASHI.Physics.YangMills.YMSourceAuthoritySurface using
  ( SourceAuthorityId ; VerificationStatus ; openTarget )
open import DASHI.Physics.YangMills.BalabanCutoffBetaLaw using
  ( BalabanCutoffCouplingDynamics ; step )
open import DASHI.Physics.YangMills.BalabanInverseSquareCouplingBudget using
  ( InverseSquareThresholdControlsCoupling
  ; BalabanBetaPrefixBound
  )

record BalabanActualBetaPrefixEstimate
    (K : ℕ)
    {γ : ℝ}
    (dynamics : BalabanCutoffCouplingDynamics K)
    (threshold : InverseSquareThresholdControlsCoupling K γ (step dynamics))
    : Set₁ where
  field
    -- This is the complete usable result: it bounds the prefix of the beta
    -- corrections generated by `dynamics`, and chooses a compatible initial
    -- inverse-square budget.  Its fields are intentionally those consumed by
    -- CMP 122, not a stronger pointwise perturbative expansion.
    prefixBudget : BalabanBetaPrefixBound K (step dynamics) threshold

    sourceAuthorityId : SourceAuthorityId
    theoremLocator : String
    status : VerificationStatus
    noClayPromotion : clayYangMillsPromoted ≡ false

open BalabanActualBetaPrefixEstimate public

actualBalabanBetaPrefixEstimateAvailable : Set
actualBalabanBetaPrefixEstimateAvailable = ⊥

currentBalabanBetaPrefixEstimateStatus : VerificationStatus
currentBalabanBetaPrefixEstimateStatus = openTarget
