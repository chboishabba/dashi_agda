module DASHI.Analysis.ThreeAdicGeometricSeries where

-- A fail-closed formal surface for
--
--   1 + 3 + 3² + 3³ + ... = -1/2
--
-- The equality is a 3-adic convergence statement, not a real-series
-- equality.  This module deliberately separates:
--
--   * finite partial sums, which are constructive;
--   * the algebraic fixed-point candidate -1/2;
--   * the genuinely analytic/metric obligation that the partial sums
--     converge to that candidate in a supplied 3-adic carrier.

open import Agda.Builtin.Nat using (Nat; zero; suc)
open import Agda.Builtin.Equality using (_≡_; refl)
open import Agda.Builtin.Unit using (⊤; tt)
open import Agda.Builtin.String using (String)
open import DASHI.Core.Q using
  ( ℚ
  ; _+ℚ_
  ; _*ℚ_
  ; _-ℚ_
  ; zeroℚ
  ; oneℚ
  ; threeℚ
  )
open import Data.Rational as R using (_/_)
open import Data.Integer using (+_)

------------------------------------------------------------------------
-- Constructive finite approximants
------------------------------------------------------------------------

pow3 : Nat → ℚ
pow3 zero    = oneℚ
pow3 (suc n) = threeℚ *ℚ pow3 n

partialSum3 : Nat → ℚ
partialSum3 zero    = zeroℚ
partialSum3 (suc n) = partialSum3 n +ℚ pow3 n

partialSum3-step : (n : Nat) →
  partialSum3 (suc n) ≡ partialSum3 n +ℚ pow3 n
partialSum3-step n = refl

------------------------------------------------------------------------
-- Canonical algebraic candidate
------------------------------------------------------------------------

minusHalf : ℚ
minusHalf = zeroℚ -ℚ ((+ 1) R./ 2)

-- The fixed-point equation generated by shifting the geometric series is
-- 3x = x - 1.  Rather than pretending that this equation alone proves
-- convergence, we package its intended candidate separately.
record ThreeAdicFixedPointCandidate : Set where
  field
    value : ℚ
    isCanonicalMinusHalf : value ≡ minusHalf

canonicalThreeAdicFixedPoint : ThreeAdicFixedPointCandidate
canonicalThreeAdicFixedPoint = record
  { value = minusHalf
  ; isCanonicalMinusHalf = refl
  }

------------------------------------------------------------------------
-- Metric/convergence boundary
------------------------------------------------------------------------

record ThreeAdicConvergenceWitness : Set₁ where
  field
    Carrier : Set
    embedℚ : ℚ → Carrier
    converges3Adically : (Nat → Carrier) → Carrier → Set
    partialSumsConverge :
      converges3Adically
        (λ n → embedℚ (partialSum3 n))
        (embedℚ minusHalf)

record ThreeAdicGeometricSeriesTheorem : Set₁ where
  field
    candidate : ThreeAdicFixedPointCandidate
    convergence : ThreeAdicConvergenceWitness
    sumValue : ℚ
    sumValueIsMinusHalf : sumValue ≡ minusHalf
    notARealConvergenceClaim : ⊤
    notAnAbelSummationClaim : ⊤
    notAZetaContinuationClaim : ⊤

threeAdicGeometricSeriesFromConvergence :
  ThreeAdicConvergenceWitness → ThreeAdicGeometricSeriesTheorem
threeAdicGeometricSeriesFromConvergence witness = record
  { candidate = canonicalThreeAdicFixedPoint
  ; convergence = witness
  ; sumValue = minusHalf
  ; sumValueIsMinusHalf = refl
  ; notARealConvergenceClaim = tt
  ; notAnAbelSummationClaim = tt
  ; notAZetaContinuationClaim = tt
  }

------------------------------------------------------------------------
-- Provenance / interpretation boundary
------------------------------------------------------------------------

record ThreeAdicGeometricSeriesProvenance : Set where
  field
    sourceSeries : String
    ambientMetric : String
    shiftEquation : String
    canonicalValue : ℚ
    finiteApproximantsConstructed : ⊤
    convergenceRequiresWitness : ⊤
    noDialecticalTheoremClaim : ⊤

threeAdicGeometricSeriesProvenance : ThreeAdicGeometricSeriesProvenance
threeAdicGeometricSeriesProvenance = record
  { sourceSeries = "sum of powers 3^n from n = 0"
  ; ambientMetric = "3-adic"
  ; shiftEquation = "3x = x - 1"
  ; canonicalValue = minusHalf
  ; finiteApproximantsConstructed = tt
  ; convergenceRequiresWitness = tt
  ; noDialecticalTheoremClaim = tt
  }
