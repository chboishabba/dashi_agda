ttps://www.hepdata.net/download/table/ins1486676/Table 3/root","yaml":"https://www.hepdata.net/download/table/ins1486676/Table 3/yaml","yoda":"https://www.hepdata.net/download/table/ins1486676/Table 3/yoda","yoda.h5":"https://www.hepdata.net/download/table/ins1486676/Table 3/yoda.h5","yoda1":"https://www.hepdata.net/download/table/ins1486676/Table 3/yoda1"},"description":"Full covariance matrix of the normalised moments. The statistical and systematic uncertainties are combined.","doi":"10.17182/hepdata.75193.v1/t3","id":66907,"location":"Data from Additional material","messages":false,"name":"Table 3","processed_name":"Table3","resources":[]}],"mode":"record","overall_status":"finished","participant_count":0,"recid":75193,"record":{"abstract":"Measurements of the differential branching fraction and angular moments of the decay $B^0 \\to K^+ \\pi^- \\mu^+ \\mu^-$ in the $K^+\\pi^-$ invariant mass range $1330<m(K^+ \\pi^-)<1530~MeV/c^2$ are presented. Proton-proton collision data are used, corresponding to an integrated luminosity of 3 $fb^{-1}$ collected by the LHCb experiment. Differential branching fraction measurements are reported in five bins of the invariant mass squared of the dimuon system, $q^2$, between 0.1 and 8.0 $GeV^2/c^4$. For the first time, an angular analysis sensitive to the S-, P- and D-wave contributions of this rare decay is performed. The set of 40 normalised angular moments describing the decay is presented for the $q^2$ range 1.1--6.0 $GeV^2/c^4$.","access_urls":{"links":{"csv":"https://www.hepdata.net/download/submission/ins1486676/1/csv","json":"https://www.hepdata.net/download/submission/ins1486676/1/json","root":"https://www.hepdata.net/download/submission/ins1486676/1/root","yaml":"https://www.hepdata.net/download/submission/ins1486676/1/yaml","yoda":"https://www.hepdata.net/download/submission/ins1486676/1/yoda"}},"analyses":[],"arxiv_id":"arXiv:1609.04736","collaborations":["LHCb"],"control_number":"75193","creation_date":"2016-09-15","data_abstract":"CERN-LHC.  Measurements of the differential branching fraction and angular moments of the decay $B^0 \\to K^+ \\pi^- \\mu^+ \\mu^-$ in the $K^*_{0,2}(1430)^0$ in the $K^+\\pi^-$ invariant mass range $1330&lt;m(K^+ \\pi^-)&lt;1530~MeV/c^2$ are presented. Proton-proton collision data are used, corresponding to an integrated luminosity of 3 $fb^{-1}$ collected by the LHCb experiment. Differential branching fraction measurements are reported in five bins of the invariant mass squared of the dimuon system, $q^2$, between 0.1 and 8.0 $GeV^2/c^4$. For the first time, an angular analysis sensitive to the S-, P- and D-wave contributions of this rare decay is performed. The set of 40 normalised angular moments describing the decay is presented for the $q^2$ range 1.1--6.0 $GeV^2/c^4$.","data_keywords":{"cmenergies":[{"gte":7000.0,"lte":8000.0}],"observables":["BR","ASYM","POL","CORR"],"phrases":["Inclusive","Asymmetry Measurement","Muon Production","Strange Production","Proton-Proton Scattering","Polarization"],"reactions":["P P --> B0 + X"]},"doc_type":"publication","doi":"10.1007/JHEP12(2016)065","first_author":{"affiliation":"CERN","full_name":"Aaij, Roel"},"hepdata_doi":"10.17182/hepdata.75193.v1","id":75193,"inspire_id":1486676,"journal_info":"JHEP 12 (2016) 065","keywords":[{"source":"author","value":"FCNC Interaction"},{"source":"author","value":"Flavor physics"},{"source":"author","value":"B physics"},{"source":"author","value":"Rare decay"},{"source":"author","value":"Hadron-Hadron scattering (experiments)"},{"schema":"INSPIRE","value":"p p: scattering"},{"schema":"INSPIRE","value":"p p: colliding beams"},{"schema":"INSPIRE","value":"B0: semileptonic decay"},{"schema":"INSPIRE","value":"B0: branching ratio"},{"schema":"INSPIRE","value":"B0: rare decay"},{"schema":"INSPIRE","value":"muon: pair production"},{"schema":"INSPIRE","value":"mass spectrum: (K+ pi-)"},{"schema":"INSPIRE","value":"dimuon: mass spectrum"},{"schema":"INSPIRE","value":"mass spec